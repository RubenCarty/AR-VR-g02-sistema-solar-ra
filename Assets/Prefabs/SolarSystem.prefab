  m_Script: {fileID: 11500000, guid: 13011b0c4b33c8f44a581aff27445ede, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  planetName: Venus
  planetIndex: 3
  visualRadius: 0.5
  description: "Es el segundo planeta del Sistema Solar.\n\nCaracter\xEDsticas\nMuy
    parecido en tama\xF1o a la Tierra.\nA\xF1o: 225 d\xEDas terrestres.\nNo tiene
    lunas.\nCuriosidades\nEs el planeta m\xE1s caliente, con unos 465 \xB0C.\nSu
    atm\xF3sfera est\xE1 formada principalmente por di\xF3xido de carbono.\nGira
    en sentido contrario al de la mayor\xEDa de los planetas.\nUn d\xEDa en Venus
    dura 243 d\xEDas terrestres, m\xE1s que su a\xF1o."
